FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./

RUN npm ci --omit=dev

COPY . .

# ---------------------------------------------------------------------------

FROM node:20-alpine

RUN apk add --no-cache tini postgresql-client

WORKDIR /app

COPY --from=build /app ./

ENV NODE_ENV=production

EXPOSE 3002

ENTRYPOINT ["/sbin/tini", "--"]

CMD ["node", "server.js"]
